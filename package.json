{
  "name": "sandbox-website-template",
  "description": "A template for building a React application with Vite, Hono, and Cloudflare Workers",
  "private": true,
  "dependencies": {
    "@runablehq/website-runtime": "^0.10.0",
    "hono": "4.12.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.26.1",
    "@eslint/js": "^9.25.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260306.1",
    "@vitejs/plugin-react": "5.1.4",
    "eslint": "^9.25.1",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.4.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.1",
    "wrangler": "^4.71.0"
  },
  "scripts": {
    "build": "tsgo && ([ ! -f autumn.config.ts ] || bunx tsc --noEmit --skipLibCheck autumn.config.ts) && vite build",
    "cf-typegen": "wrangler types",
    "check": "tsgo && vite build && wrangler deploy --dry-run",
    "dev": "vite",
    "lint": "eslint .",
    "preview": "bun run build && vite preview"
  },
  "type": "module"
}
